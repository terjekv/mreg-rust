MREG_LISTEN=127.0.0.1
MREG_PORT=8080
MREG_STORAGE_BACKEND=auto
MREG_JSON_PAYLOAD_LIMIT_BYTES=1048576
MREG_DATABASE_URL=postgres://mreg:mreg@localhost:5432/mreg
MREG_TEST_DATABASE_URL=postgres://mreg:mreg@localhost:5432/mreg_test
MREG_RUN_MIGRATIONS=true
MREG_JSON_LOGS=false
MREG_TREETOP_URL=http://localhost:9999
MREG_TREETOP_TIMEOUT_MS=1500
MREG_ALLOW_DEV_AUTHZ_BYPASS=true
MREG_TEST_TREETOP_URL=http://127.0.0.1:9999

# Authentication: none or scoped
MREG_AUTH_MODE=none
MREG_AUTH_TOKEN_TTL_SECONDS=3600
MREG_AUTH_JWT_ISSUER=mreg-rust

# Scoped authentication
# MREG_AUTH_MODE=scoped
# MREG_AUTH_JWT_SIGNING_KEY=change-me
# MREG_AUTH_SCOPES_FILE=auth-scopes.local.json

# See auth-scopes.example.json for local, ldap, and remote scope examples.

# Auto-create DHCP identifiers from attachment MAC address on IP assignment
MREG_DHCP_AUTO_V4_CLIENT_ID=false
MREG_DHCP_AUTO_V6_DUID_LL=false
